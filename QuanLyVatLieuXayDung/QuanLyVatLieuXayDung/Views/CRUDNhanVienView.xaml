<Window x:Class="QuanLyVatLieuXayDung.Views.CRUDNhanVienView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyVatLieuXayDung.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:uc="clr-namespace:QuanLyVatLieuXayDung.UserControlVLXD"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Name="window"
        Title="Nhân viên" Height="500" Width="750">

    <Grid Background="#ECF0F1">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <uc:ucControlBar Tag="{Binding Title,ElementName=window}"></uc:ucControlBar>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <!-- THÔNG TIN NHÂN VIÊN -->
            <materialDesign:Card Grid.Row="0" Margin="5">
                <GroupBox Height="auto" Header=" Thông tin nhân viên " Margin="5">
                    <StackPanel Height="auto">
                        <TextBlock Height="5"></TextBlock>

                        <!-- Dòng 1 -->
                        <StackPanel Orientation="Horizontal" Height="35" >
                            <Label Content="Tên đăng nhập: " Margin="15 0 0 0" Width="110" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="250" Height="30" Margin="0 0 5 0" Background="White">
                                <TextBox Text="{Binding UserName,UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>

                            <Label Content="Quyền: " Width="60" VerticalAlignment="Center" Margin="5 0 0 0"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="250" Height="30" Background="White">
                                <ComboBox ItemsSource="{Binding Role}" 
                                          SelectedItem="{Binding SelectedRole,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                          Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Height="10"></TextBlock>

                        <!-- Dòng 2 -->
                        <StackPanel Orientation="Horizontal" Height="35" >
                            <Label Content="Tên hiển thị: " Margin="15 0 0 0" Width="110" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="250" Height="30" Background="White">
                                <TextBox Text="{Binding DisplayName}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Height="5"></TextBlock>
                    </StackPanel>
                </GroupBox>
            </materialDesign:Card>

            <!-- DANH SÁCH LISTVIEW -->
            <materialDesign:Card Grid.Row="1" Margin="5" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListView ItemsSource="{Binding ListType}" SelectedItem="{Binding SelectedType,Mode=OneWayToSource}">
                        <ListView.Resources>
                            <Style TargetType="{x:Type GridViewColumnHeader}">
                                <Setter Property="Padding" Value="10,8" />
                                <Setter Property="BorderBrush" Value="#BDC3C7" />
                                <Setter Property="Background" Value="#FAFAFA" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                                            <Border BorderThickness="0,0,1,1" BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style TargetType="{x:Type ListViewItem}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,2"/>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" DisplayMemberBinding="{Binding ID}"></GridViewColumn>
                                <GridViewColumn Header="Tên đăng nhập" DisplayMemberBinding="{Binding UserName}"></GridViewColumn>
                                <GridViewColumn Header="Chức vụ" DisplayMemberBinding="{Binding Role.DisplayName}"></GridViewColumn>
                                <GridViewColumn Header="Tên hiển thị" DisplayMemberBinding="{Binding DisplayName}"></GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>
            </materialDesign:Card>

            <!-- THANH NÚT BẤM -->
            <materialDesign:Card Grid.Row="2" Margin="5">
                <WrapPanel HorizontalAlignment="Center" Margin="0,5,0,5" >
                    <WrapPanel.Resources>
                        <!-- Style Button tự định nghĩa để bo góc không dùng StaticResource -->
                        <Style TargetType="Button">
                            <Setter Property="Height" Value="35"/>
                            <Setter Property="Width" Value="100"/>
                            <Setter Property="Margin" Value="10,5,10,5"/>
                            <Setter Property="Background" Value="#E67E22"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#D2691E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </WrapPanel.Resources>

                    <Button Command="{Binding AddCommand}" Content="Thêm" />
                    <Button Command="{Binding UpdateCommand}" Content="Sửa" />
                    <Button Command="{Binding RemoveCommand}" Content="Xóa" />
                    <Button Command="{Binding ChangePasswordCommand}" Content="Đổi pass" />
                </WrapPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>