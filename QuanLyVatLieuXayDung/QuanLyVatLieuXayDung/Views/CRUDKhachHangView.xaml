<Window x:Class="QuanLyVatLieuXayDung.Views.CRUDKhachHangView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyVatLieuXayDung.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:uc="clr-namespace:QuanLyVatLieuXayDung.UserControlVLXD"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Name="window"
        Title="Khách hàng" Height="500" Width="850">

    <Window.DataContext>
        <local:KhachHangViewModel/>
    </Window.DataContext>

    <Grid Background="#ECEFF1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <uc:ucControlBar Tag="{Binding Title,ElementName=window}"></uc:ucControlBar>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Margin="5">
                <GroupBox Height="Auto" Header=" Thông tin khách hàng " Margin="5">
                    <StackPanel Height="Auto">
                        <TextBlock Height="5"></TextBlock>

                        <StackPanel Orientation="Horizontal" Height="35" >
                            <Label Content="Tên khách hàng: " Margin="15 0 0 0" Width="110" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="240" Height="30" Margin="0 0 5 0" Background="White">
                                <TextBox Text="{Binding DisplayName,UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>

                            <Label Content="Địa chỉ: " Width="90" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="240" Height="30" Background="White">
                                <TextBox Text="{Binding Address,UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Height="10"></TextBlock>

                        <StackPanel Orientation="Horizontal" Height="35" >
                            <Label Content="Số điện thoại: " Margin="15 0 0 0" Width="110" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="240" Height="30" Margin="0 0 5 0" Background="White">
                                <TextBox Text="{Binding Phone,UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>

                            <Label Content="Email: "  Width="90" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="240" Height="30" Background="White">
                                <TextBox Text="{Binding Email,UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Height="10"></TextBlock>

                        <StackPanel Orientation="Horizontal" Height="35">
                            <Label Content="Thông tin thêm: " Margin="15 0 0 0" Width="110" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="240" Height="30" Margin="0 0 5 0" Background="White">
                                <TextBox Text="{Binding MoreInfo,UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>

                            <Label Content="Ngày hợp tác: "  Width="90" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="240" Height="30" Background="White">
                                <DatePicker IsEnabled="True" SelectedDate="{Binding ContractDate,UpdateSourceTrigger=PropertyChanged,StringFormat='dd/MM/yyyy'}" 
                                            Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Height="5"></TextBlock>
                    </StackPanel>
                </GroupBox>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" Margin="5" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
                        <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Background="White" Height="35" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" VerticalAlignment="Center" Foreground="#90A4AE" Margin="10,0,5,0"/>
                                <Grid>
                                    <TextBlock Text="Tìm kiếm theo mã, tên khách hàng..." Foreground="#B0BEC5" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="13" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox x:Name="txtSearch" Width="250" 
                                             BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" FontSize="13" Padding="5,0,5,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <Label Content="Từ ngày:" VerticalAlignment="Center"/>
                        <DatePicker Width="120" Margin="5,0,10,0" SelectedDate="{Binding FilterTuNgay, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <Label Content="Đến ngày:" VerticalAlignment="Center"/>
                        <DatePicker Width="120" Margin="5,0,10,0" SelectedDate="{Binding FilterDenNgay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                <ListView Grid.Row="1" ItemsSource="{Binding KhachHangView}" 
                          SelectedItem="{Binding SelectedKH,Mode=TwoWay}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.Resources>
                        <Style TargetType="{x:Type GridViewColumnHeader}">
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="BorderBrush" Value="#BDC3C7" />
                            <Setter Property="Background" Value="#FAFAFA" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                                        <Border BorderThickness="0,0,1,1" BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="{x:Type ListViewItem}">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0,2"/>
                        </Style>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="STT" Width="45" DisplayMemberBinding="{Binding STT}"></GridViewColumn>
                            <GridViewColumn Header="ID" Width="70" DisplayMemberBinding="{Binding ID}"></GridViewColumn>
                            <GridViewColumn Header="Họ Tên" Width="120" DisplayMemberBinding="{Binding DisplayName}"></GridViewColumn>
                            <GridViewColumn Header="Địa chỉ" Width="120" DisplayMemberBinding="{Binding Address}"></GridViewColumn>
                            <GridViewColumn Header="SĐT" Width="100" DisplayMemberBinding="{Binding Phone}"></GridViewColumn>
                            <GridViewColumn Header="Email" Width="120" DisplayMemberBinding="{Binding Email}"></GridViewColumn>
                            <GridViewColumn Header="Ghi chú" Width="80" DisplayMemberBinding="{Binding MoreInfo}"></GridViewColumn>
                            <GridViewColumn Header="Tổng công nợ" Width="110" DisplayMemberBinding="{Binding CongNoHienTai, StringFormat='{}{0:N0} VND'}"></GridViewColumn>
                            <GridViewColumn Header="Ngày hợp tác" Width="150" DisplayMemberBinding="{Binding ContractDate,StringFormat='dd/MM/yyyy'}"></GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2" Margin="5">
                <WrapPanel HorizontalAlignment="Center" Margin="0,5,0,5" >
                    <WrapPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Height" Value="35"/>
                            <Setter Property="Width" Value="100"/>
                            <Setter Property="Margin" Value="10,5,10,5"/>
                            <Setter Property="Background" Value="#4CAF50"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#388E3C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </WrapPanel.Resources>
                    <Button Command="{Binding AddCommand}" Content="Thêm mới" />
                    <Button Command="{Binding UpdateCommand}" Content="Cập nhật" Background="#FF9800"/>
                    <Button Command="{Binding RemoveCommand}" Content="Xóa bỏ" Background="#F44336"/>
                </WrapPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>