<Window x:Class="QuanLyVatLieuXayDung.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyVatLieuXayDung.Views"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="700" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        >
    <!--Background Grid-->
    <Grid Background="#23262B">
        <TextBlock Text="Tên Thương Hiệu"
                   Foreground="#525965"
                   FontFamily="../Resources/Fonts/Orbitron/#Orbitron Medium"
                   FontSize="10"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Right"
                   Margin="0,0,15,10"/>
        <Border Background="#D61734"
                Height="15"
                CornerRadius="3,0,0,3"
                Width="5"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="0,0,0,8"/>
        <!--Menu Panel-->
        <StackPanel Background="#2E333A"
                    Width="230"
                    Orientation="Vertical"
                    HorizontalAlignment="Left">
            <!--Channel Name-->
                <Grid Height="50"
                  VerticalAlignment="Top"
                  Margin="0,30,0,0">
                <Border Background="#D61734"
                        Height="25"
                        CornerRadius="3,0,0,3"
                        Width="6"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"/>
                <TextBlock Text="Tên Thương Hiệu"
                           Foreground="#FFFFFF"
                           FontFamily="../Resources/Fonts/Orbitron/#Orbitron Medium"
                           FontSize="15"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Grid>
            <!--Main Menu-->
            <Menu Height="450"
                  Background="Transparent"
                  Margin="0,40,0,0">
                <Menu.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </Menu.ItemsPanel>
                <!--Main Menu - Home-->
                <MenuItem Header="Home"
                          Template="{StaticResource Menu_Template}"
                          >
                    <MenuItem.Icon>
                        <Image Source="/Assets/Icon/house.png"
                               Stretch="Uniform"/>

                    </MenuItem.Icon>
                </MenuItem>
                <!--Menu - Quản Lý Kho-->
                <MenuItem Header="Quản Lý Kho" 
                          Template="{StaticResource Menu_Template}">
                    <MenuItem.Icon>
                        <Image Source="/Assets/Icon/warehouse.png" Stretch="Uniform"/>
                    </MenuItem.Icon>
                    <!--SubMenu - Quản Lý Kho-->
                        <MenuItem Header="Danh mục vật liệu" 
                              Template="{StaticResource Menu_SubMenu_Template}">
                        <MenuItem.Icon>
                            <Image Source="/Assets/Icon/construction.png"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Nhập kho vật liệu" 
                              Template="{StaticResource Menu_SubMenu_Template}">
                        <MenuItem.Icon>
                            <Image Source="/Assets/Icon/income.png"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Kiểm kê tồn kho" 
                                Template="{StaticResource Menu_SubMenu_Template}">
                        <MenuItem.Icon>
                            <Image Source="/Assets/Icon/search.png"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <!--Menu - Bán Hàng-->
                    <MenuItem Header="Bán hàng"
                          Template="{StaticResource Menu_Template}">
                    <MenuItem.Icon>
                        <Image Source="/Assets/Icon/cashier.png"
                               Stretch="Uniform"/>
                    </MenuItem.Icon>
                    <!--SubMenu - Bán Hàng-->
                    <MenuItem Header="Lập hóa đơn" 
                              Template="{StaticResource Menu_SubMenu_Template}">
                        <MenuItem.Icon>
                            <Image Source="/Assets/Icon/bill.png"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Lịch sử bán hàng" 
                              Template="{StaticResource Menu_SubMenu_Template}">
                        <MenuItem.Icon>
                            <Image Source="/Assets/Icon/file.png"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <!--Menu - Đối tác-->
                    <MenuItem Header="Đối tác"
                          Template="{StaticResource Menu_Template}">
                    <MenuItem.Icon>
                        <Image Source="/Assets/Icon/handshake.png"
                               Stretch="Uniform"/>

                    </MenuItem.Icon>
                    <!--SubMenu - Đối tác-->
                    <MenuItem Header="Khách hàng" 
                              Template="{StaticResource Menu_SubMenu_Template}">
                        <MenuItem.Icon>
                            <Image Source="/Assets/Icon/rating.png"/>
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem Header="Nhà cung cấp" 
                              Template="{StaticResource Menu_SubMenu_Template}">
                        <MenuItem.Icon>
                            <Image Source="/Assets/Icon/manufacture.png"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <!--Menu - Thống kê-->
                    <MenuItem Header="Thống kê"
                          Template="{StaticResource Menu_Template}">
                    <MenuItem.Icon>
                        <Image Source="/Assets/Icon/statistics.png"
                               Stretch="Uniform"/>
                    </MenuItem.Icon>
                </MenuItem>
            </Menu>
        </StackPanel>
    </Grid>
</Window>
