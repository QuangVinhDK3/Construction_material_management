<Window x:Class="QuanLyVatLieuXayDung.Views.CRUDPhieuNhapView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyVatLieuXayDung.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:uc="clr-namespace:QuanLyVatLieuXayDung.UserControlVLXD"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Name="window"
        Title="Chi tiết phiếu nhập" Height="500" Width="850">
    <Window.DataContext>
        <local:PhieuNhapViewModel/>
    </Window.DataContext>
    <Grid Background="#ECEFF1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <uc:ucControlBar Tag="{Binding Title,ElementName=window}"></uc:ucControlBar>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Margin="5">
                <GroupBox Height="auto" Header=" Thông tin phiếu nhập " Margin="5">
                    <Grid Margin="10,5,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Vật liệu | Mã phiếu nhập -->
                        <Label Grid.Row="0" Grid.Column="0" Content="Vật liệu:" VerticalAlignment="Center" Padding="0,0,8,0"/>
                        <Border Grid.Row="0" Grid.Column="1" CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Height="30" Background="White" Margin="0,5,15,5">
                            <ComboBox ItemsSource="{Binding DSVatLieu}"
                                      SelectedItem="{Binding SelectedVL}"
                                      SelectedValue="{Binding IDVatLieu, Mode=TwoWay}"
                                      SelectedValuePath="ID"
                                      DisplayMemberPath="DisplayName"
                                      Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                        </Border>

                        <Label Grid.Row="0" Grid.Column="2" Content="Mã phiếu nhập:" VerticalAlignment="Center" Padding="0,0,8,0"/>
                        <Border Grid.Row="0" Grid.Column="3" CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Height="30" Background="White" Margin="0,5,0,5">
                            <ComboBox ItemsSource="{Binding DSPhieuNhap}"
                                      SelectedItem="{Binding SelectedPN}"
                                      SelectedValue="{Binding IDPhieuNhap, Mode=TwoWay}"
                                      SelectedValuePath="ID"
                                      DisplayMemberPath="ID"
                                      Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                        </Border>

                        <!-- Row 1: Số lượng | Giá nhập -->
                        <Label Grid.Row="1" Grid.Column="0" Content="Số lượng:" VerticalAlignment="Center" Padding="0,0,8,0"/>
                        <Border Grid.Row="1" Grid.Column="1" CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Height="30" Background="White" Margin="0,5,15,5">
                            <TextBox Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                        </Border>

                        <Label Grid.Row="1" Grid.Column="2" Content="Giá nhập:" VerticalAlignment="Center" Padding="0,0,8,0"/>
                        <Border Grid.Row="1" Grid.Column="3" CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Height="30" Background="White" Margin="0,5,0,5">
                            <TextBox Text="{Binding PriceInput, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                        </Border>

                        <!-- Row 2: Giá xuất -->
                        <Label Grid.Row="2" Grid.Column="0" Content="Giá xuất:" VerticalAlignment="Center" Padding="0,0,8,0"/>
                        <Border Grid.Row="2" Grid.Column="1" CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Height="30" Background="White" Margin="0,5,15,5">
                            <TextBox Text="{Binding PriceOutput, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                        </Border>
                    </Grid>
                </GroupBox>
            </materialDesign:Card>


            <materialDesign:Card Grid.Row="1" Margin="5" VerticalAlignment="Stretch">
                <ListView ItemsSource="{Binding DSCTPhieuNhap}" 
                          SelectedItem="{Binding SelectedCTPN,Mode=TwoWay}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="STT" Width="45" DisplayMemberBinding="{Binding STT}"></GridViewColumn>
                            <GridViewColumn Header="Mã chi tiết" Width="100" DisplayMemberBinding="{Binding ID}"></GridViewColumn>
                            <GridViewColumn Header="Tên vật liệu" Width="160" DisplayMemberBinding="{Binding VatLieu.DisplayName}"></GridViewColumn>
                            <GridViewColumn Header="Mã phiếu nhập" Width="100" DisplayMemberBinding="{Binding IDINput}"></GridViewColumn>
                            <GridViewColumn Header="Số lượng" Width="80" DisplayMemberBinding="{Binding Counts}"></GridViewColumn>
                            <GridViewColumn Header="Giá nhập" Width="100" DisplayMemberBinding="{Binding PriceInput, StringFormat='{}{0:N0} VND'}"></GridViewColumn>
                            <GridViewColumn Header="Giá xuất" Width="100" DisplayMemberBinding="{Binding PriceOutput, StringFormat='{}{0:N0} VND'}"></GridViewColumn>
                            <GridViewColumn Header="Thành tiền" Width="120" DisplayMemberBinding="{Binding ThanhTien, StringFormat='{}{0:N0} VND'}"></GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2" Margin="5">
                <WrapPanel HorizontalAlignment="Center" Margin="0 5 0 5">
                    <WrapPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Height" Value="35"/>
                            <Setter Property="Width" Value="100"/>
                            <Setter Property="Margin" Value="10 5 10 5"/>
                            <Setter Property="Background" Value="#4CAF50"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#388E3C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </WrapPanel.Resources>

                    <Button Command="{Binding AddCommand}" Content="Thêm" />
                    <Button Command="{Binding UpdateCommand}" Content="Sửa" Background="#FF9800"/>
                    <Button Command="{Binding RemoveCommand}" Content="Xóa" Background="#F44336"/>
                </WrapPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>