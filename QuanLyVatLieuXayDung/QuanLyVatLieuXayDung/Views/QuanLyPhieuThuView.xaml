<Window x:Class="QuanLyVatLieuXayDung.Views.QuanLyPhieuThuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyVatLieuXayDung.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:uc="clr-namespace:QuanLyVatLieuXayDung.UserControlVLXD"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Name="window"
        Title="Sổ quỹ - Phiếu Thu" Height="550" Width="850">
    <Window.DataContext>
        <local:PhieuThuViewModel/>
    </Window.DataContext>
    <Grid Background="#ECEFF1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <uc:ucControlBar Tag="{Binding Title,ElementName=window}"></uc:ucControlBar>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Margin="5">
                <GroupBox Header="Thông tin phiếu thu" Margin="5" materialDesign:ColorZoneAssist.Mode="Custom" materialDesign:ColorZoneAssist.Background="#1976D2" materialDesign:ColorZoneAssist.Foreground="White">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Height="35" Margin="0 5 0 0">
                            <Label Content="Khách hàng: " Margin="5 0 0 0" Width="90" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="300" Height="30" Background="White">
                                <ComboBox ItemsSource="{Binding DSKhachHang}" 
                                          SelectedItem="{Binding SelectedKhachHang}"
                                          SelectedValue="{Binding IDKhachHang, Mode=TwoWay}"
                                          SelectedValuePath="ID"
                                          DisplayMemberPath="DisplayName"
                                          Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>

                            <Label Content="Ngày thu: " Margin="20 0 0 0" Width="80" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="150" Height="30" Background="White">
                                <DatePicker IsEnabled="True" SelectedDate="{Binding NgayThu,UpdateSourceTrigger=PropertyChanged}" 
                                            Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Height="35" Margin="0 5 0 0">
                            <Label Content="Số tiền thu: " Margin="5 0 0 0" Width="90" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="300" Height="30" Background="White">
                                <TextBox Text="{Binding SoTien, Mode=TwoWay, StringFormat='{}{0:N0}'}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>
                            <Label Content="VND" VerticalAlignment="Center" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Height="35" Margin="0 5 0 0">
                            <Label Content="Nội dung: " Margin="5 0 0 0" Width="90" VerticalAlignment="Center"/>
                            <Border CornerRadius="5" BorderBrush="#B0BEC5" BorderThickness="1" Width="680" Height="30" Background="White">
                                <TextBox Text="{Binding NoiDung, Mode=TwoWay}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Height="5"></TextBlock>
                    </StackPanel>
                </GroupBox>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="1" Margin="5" VerticalAlignment="Stretch">
                <ListView ItemsSource="{Binding DSPhieuThu}" 
                          SelectedItem="{Binding SelectedPhieuThu,Mode=TwoWay}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="Height" Value="35"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Mã PT" Width="80" DisplayMemberBinding="{Binding ID}"></GridViewColumn>
                            <GridViewColumn Header="Ngày thu" Width="120" DisplayMemberBinding="{Binding NgayThu, StringFormat='dd/MM/yyyy HH:mm'}"></GridViewColumn>
                            <GridViewColumn Header="Người lập" Width="130" DisplayMemberBinding="{Binding NguoiDung.DisplayName}"></GridViewColumn>
                            <GridViewColumn Header="Khách hàng" Width="160" DisplayMemberBinding="{Binding KhachHang.DisplayName}"></GridViewColumn>
                            <GridViewColumn Header="Số tiền" Width="120" DisplayMemberBinding="{Binding SoTien, StringFormat='{}{0:N0} VND'}"></GridViewColumn>
                            <GridViewColumn Header="Nội dung" Width="200" DisplayMemberBinding="{Binding NoiDung}"></GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2" Margin="5">
                <WrapPanel HorizontalAlignment="Center" Margin="0 5 0 5">
                    <WrapPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Height" Value="35"/>
                            <Setter Property="Width" Value="100"/>
                            <Setter Property="Margin" Value="10 5 10 5"/>
                            <Setter Property="Background" Value="#4CAF50"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#388E3C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </WrapPanel.Resources>

                    <Button Command="{Binding AddCommand}" Content="Lập phiếu thu" />
                    <Button Command="{Binding UpdateCommand}" Content="Sửa" Background="#FF9800"/>
                    <Button Command="{Binding RemoveCommand}" Content="Xóa" Background="#F44336"/>
                </WrapPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>
